{
  "name": "@foxfang/nextcloud-talk",
  "version": "2026.3.27",
  "description": "FoxFang Nextcloud Talk channel plugin",
  "type": "module",
  "devDependencies": {
    "foxfang": "workspace:*"
  },
  "peerDependencies": {
    "foxfang": ">=2026.3.27"
  },
  "peerDependenciesMeta": {
    "foxfang": {
      "optional": true
    }
  },
  "foxfang": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nextcloud-talk",
      "label": "Nextcloud Talk",
      "selectionLabel": "Nextcloud Talk (self-hosted)",
      "docsPath": "/channels/nextcloud-talk",
      "docsLabel": "nextcloud-talk",
      "blurb": "Self-hosted chat via Nextcloud Talk webhook bots.",
      "aliases": [
        "nc-talk",
        "nc"
      ],
      "order": 65,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@foxfang/nextcloud-talk",
      "localPath": "extensions/nextcloud-talk",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.27"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
