{
  "name": "@foxfang/synology-chat",
  "version": "2026.3.27",
  "description": "Synology Chat channel plugin for FoxFang",
  "type": "module",
  "foxfang": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "synology-chat",
      "label": "Synology Chat",
      "selectionLabel": "Synology Chat (Webhook)",
      "docsPath": "/channels/synology-chat",
      "docsLabel": "synology-chat",
      "blurb": "Connect your Synology NAS Chat to FoxFang with full agent capabilities.",
      "order": 90
    },
    "install": {
      "npmSpec": "@foxfang/synology-chat",
      "localPath": "extensions/synology-chat",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.27"
    }
  }
}
