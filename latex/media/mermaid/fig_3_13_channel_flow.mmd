---
config:
  theme: base
  themeVariables:
    fontFamily: 'Helvetica, Arial, sans-serif'
    fontSize: '15px'
    primaryColor: '#EAF2FB'
    primaryBorderColor: '#1A73E8'
    primaryTextColor: '#1A2330'
    lineColor: '#5F6368'
    tertiaryColor: '#F5F7FA'
---
%%{init: {'flowchart': {'curve': 'linear'}}}%%
flowchart TB
    classDef stepNode fill:#EAF2FB,stroke:#1A73E8,color:#1A2330
    classDef stageBox fill:#FFFFFF,stroke:#5F6368,color:#1A2330

    subgraph ST1["1. Messaging Platform"]
        M1["Slack, Discord, Telegram, ..."]
    end

    subgraph ST2["2. Inbound Channel Processing"]
        M2["Channel Adapter or Plugin"] --> M3["Normalize Inbound Message"] --> M4["Resolve Sender, Thread and Session"]
    end

    subgraph ST3["3. Gateway and Agent Processing"]
        M5["Gateway / Agent Runtime"] --> M6["Reply Payload"]
    end

    subgraph ST4["4. Outbound Delivery"]
        M7["Message Delivery Adapter"]
        M8["Send response back to<br/>Messaging Platform (step 1)"]
        M7 --> M8
    end

    ST1 --> ST2 --> ST3 --> ST4

    class M1,M2,M3,M4,M5,M6,M7,M8 stepNode
    class ST1,ST2,ST3,ST4 stageBox
