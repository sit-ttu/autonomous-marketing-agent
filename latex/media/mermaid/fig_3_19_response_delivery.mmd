---
config:
  theme: base
  themeVariables:
    fontFamily: 'Helvetica, Arial, sans-serif'
    fontSize: '15px'
    primaryColor: '#EAF2FB'
    primaryBorderColor: '#1A73E8'
    primaryTextColor: '#1A2330'
    lineColor: '#5F6368'
    tertiaryColor: '#F5F7FA'
---
%%{init: {'flowchart': {'curve': 'linear'}}}%%
flowchart TB
    classDef stepNode fill:#EAF2FB,stroke:#1A73E8,color:#1A2330
    classDef decisionNode fill:#FEF7E0,stroke:#B06000,color:#5C3C00
    classDef stageBox fill:#FFFFFF,stroke:#5F6368,color:#1A2330

    subgraph RP1["1. Response Preparation"]
        E1["Agent Final Reply"] --> E2["Reply Payload"] --> E3["Resolve Delivery Context"]
    end

    subgraph RP2["2. Delivery Routing"]
        E4{"Channel target?"}
        E4 -- "CLI / Web" --> E5["Render Locally"]
        E4 -- "Messaging Channel" --> E6["Message Tool<br/>or Adapter"]
        E4 -- "Webhook" --> E7["HTTP Delivery"]
    end

    subgraph RP3["3. External Delivery"]
        E8["Platform API"]
        E9["Webhook Endpoint"]
    end

    E10["4. User Output:<br/>user receives the response"]:::stepNode

    RP1 --> RP2
    E5 --> E10
    E6 --> E8 --> E10
    E7 --> E9 --> E10

    class E1,E2,E3,E5,E6,E7,E8,E9 stepNode
    class E4 decisionNode
    class RP1,RP2,RP3 stageBox
