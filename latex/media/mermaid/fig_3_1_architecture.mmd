---
config:
  theme: base
  themeVariables:
    fontFamily: 'Helvetica, Arial, sans-serif'
    fontSize: '15px'
    primaryColor: '#F1F3F4'
    primaryBorderColor: '#9AA0A6'
    primaryTextColor: '#1A2330'
    lineColor: '#5F6368'
    tertiaryColor: '#F5F7FA'
---
flowchart TB
    classDef baseNode fill:#F1F3F4,stroke:#9AA0A6,color:#3C4043
    classDef adjustNode fill:#FEF7E0,stroke:#B06000,color:#5C3C00,font-weight:bold
    classDef customNode fill:#E6F4EA,stroke:#137333,color:#0D652D,font-weight:bold
    classDef layerBox fill:#FFFFFF,stroke:#5F6368,color:#1A2330

    subgraph L1["Client Layer"]
        direction LR
        C1["CLI, Web Control UI,<br/>Paired nodes"]
        C2["Messaging channel<br/>(Telegram, configured<br/>for the marketing agent)"]
        C1 ~~~ C2
    end

    subgraph L2["Gateway Runtime"]
        direction LR
        G1["Gateway server,<br/>method handlers"]
        G2["Channel registry,<br/>Plugin runtime"]
        G3["WebSocket / HTTP APIs,<br/>Cron scheduler"]
        G1 ~~~ G2 ~~~ G3
    end

    subgraph L3["Agent Runtime"]
        direction LR
        A1["agentCommand,<br/>Runtime selector,<br/>Session resolver"]
        A2["CLI backend / ACP /<br/>Embedded Pi runtime"]
        A3["Model router,<br/>Subagent runtime"]
        A4["Context engine:<br/>loads Brand Context<br/>before content generation"]
        A5["Tool Policy:<br/>added rule blocking<br/>outbound marketing actions"]
        A1 ~~~ A2 ~~~ A3 ~~~ A4 ~~~ A5
    end

    subgraph L4["Capability Layer"]
        direction LR
        P1["Core tools, Plugin hooks,<br/>Media providers"]
        P2["Model providers,<br/>Channel plugins,<br/>Memory plugin"]
        P3["Marketing Tools:<br/>draft creation, channel variants,<br/>Approval request/resolve, scheduling"]
        P1 ~~~ P2 ~~~ P3
    end

    subgraph L5["Storage Layer"]
        direction LR
        S1["Session transcript,<br/>Memory index (SQLite),<br/>Workspace memory"]
        S2["Credentials / SecretRef,<br/>Cron jobs & run logs"]
        S3["Marketing Store:<br/>Brand, Product, Campaign,<br/>ContentPlan, PostDraft,<br/>Approval, Insight, Lead<br/>+ PostDraft/Approval state machines"]
        S1 ~~~ S2 ~~~ S3
    end

    L1 --> L2 --> L3
    L3 --> L4
    L3 <--> L5
    L4 <--> L5

    class C1,G1,G2,G3,A1,A2,A3,P1,P2,S1,S2 baseNode
    class C2,A4,A5 adjustNode
    class P3,S3 customNode
    class L1,L2,L3,L4,L5 layerBox
