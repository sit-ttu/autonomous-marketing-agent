---
config:
  theme: base
  themeVariables:
    fontFamily: 'Helvetica, Arial, sans-serif'
    fontSize: '15px'
    primaryColor: '#EAF2FB'
    primaryBorderColor: '#1A73E8'
    primaryTextColor: '#1A2330'
    lineColor: '#5F6368'
    tertiaryColor: '#F5F7FA'
---
%%{init: {'flowchart': {'curve': 'linear'}}}%%
flowchart TB
    classDef stepNode fill:#EAF2FB,stroke:#1A73E8,color:#1A2330
    classDef decisionNode fill:#FEF7E0,stroke:#B06000,color:#5C3C00
    classDef stageBox fill:#FFFFFF,stroke:#5F6368,color:#1A2330

    subgraph S1["1. Intake"]
        I1["Inbound request<br/>or marketing brief"] --> I2["agentCommand"]
    end

    subgraph S2["2. Resolve & Prepare"]
        R1["Resolve agent,<br/>session, workspace"] --> R2["Load skills,<br/>context, config"] --> R3["Select runtime"]
    end

    subgraph S3["3. Runtime Selection"]
        T0{"Runtime type?"}
        T0 --> T1["CLI backend runtime"]
        T0 --> T2["ACP runtime"]
        T0 --> T3["Embedded Pi<br/>agent runtime"]
    end

    subgraph S4["4. Agent Execution"]
        E1["Build prompt<br/>and tool schema"] --> E2["Model call"]
        E2 --> E3{"Tool call needed?"}
        E3 -- Yes --> E4["Execute tool<br/>(via Tool Policy)"]
        E4 --> E2
        E3 -- No --> E5["Generate final response"]
    end

    subgraph S5["5. Persist & Return"]
        P1["Persist Transcript,<br/>session, usage"] --> P2["Return reply payload"]
    end

    S1 --> S2 --> S3 --> S4 --> S5

    class I1,I2,R1,R2,R3,T1,T2,T3,E1,E2,E4,E5,P1,P2 stepNode
    class T0,E3 decisionNode
    class S1,S2,S3,S4,S5 stageBox
