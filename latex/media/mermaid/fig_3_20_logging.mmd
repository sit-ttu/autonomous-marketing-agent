---
config:
  theme: base
  themeVariables:
    fontFamily: 'Helvetica, Arial, sans-serif'
    fontSize: '15px'
    primaryColor: '#EAF2FB'
    primaryBorderColor: '#1A73E8'
    primaryTextColor: '#1A2330'
    lineColor: '#5F6368'
    tertiaryColor: '#F5F7FA'
---
%%{init: {'flowchart': {'curve': 'linear'}}}%%
flowchart TB
    classDef stepNode fill:#EAF2FB,stroke:#1A73E8,color:#1A2330
    classDef stageBox fill:#FFFFFF,stroke:#5F6368,color:#1A2330

    subgraph LG1["1. Runtime Data Sources"]
        direction LR
        F1["Tool Event"]
        F2["Runtime Event"]
        F3["Model Usage"]
        F4["Cron Run Outcome"]
        F1 ~~~ F2 ~~~ F3 ~~~ F4
    end

    subgraph LG2["2. Persistent Logs and Metadata"]
        direction LR
        F5["Transcript JSONL"]
        F6["Session Metadata"]
        F7["Cron Run Logs JSONL"]
        F5 ~~~ F6 ~~~ F7
    end

    subgraph LG3["3. Status and History Views"]
        F8["Status and History Views"]
    end

    F1 --> F5
    F2 --> F5
    F3 --> F6
    F4 --> F7
    F5 --> F8
    F6 --> F8
    F7 --> F8

    class F1,F2,F3,F4,F5,F6,F7,F8 stepNode
    class LG1,LG2,LG3 stageBox
