---
config:
  theme: base
  themeVariables:
    fontFamily: 'Helvetica, Arial, sans-serif'
    fontSize: '15px'
    primaryColor: '#EAF2FB'
    primaryBorderColor: '#1A73E8'
    primaryTextColor: '#1A2330'
    lineColor: '#5F6368'
    tertiaryColor: '#F5F7FA'
---
%%{init: {'flowchart': {'curve': 'linear'}}}%%
flowchart TB
    classDef stepNode fill:#EAF2FB,stroke:#1A73E8,color:#1A2330
    classDef decisionNode fill:#FEF7E0,stroke:#B06000,color:#5C3C00
    classDef stageBox fill:#FFFFFF,stroke:#5F6368,color:#1A2330

    subgraph SC1["1. Schedule Creation"]
        C1["User or Agent<br/>creates schedule"] --> C2["Validate schedule<br/>and payload"]
    end

    subgraph SC2["2. Job Persistence"]
        C3["Parse Cron Job"] --> C4["Cron Job Storage"]
    end

    subgraph SC3["3. Scheduler Runtime"]
        C5["Gateway Cron Scheduler"] --> C6{"Due job?"}
        C6 -- "Not yet" --> C5
    end

    subgraph SC4["4. Job Dispatch"]
        C7["Append event<br/>to Session"] --> C8["Dispatch Agent Turn"] --> C9["Agent Runtime"]
    end

    subgraph SC5["5. Delivery and Logging"]
        C10["Optional Delivery"] --> C11["Run Log & Job State"] --> C12["Cron Run Logs"]
    end

    SC1 --> SC2 --> SC3
    C6 -- Due --> SC4
    SC4 --> SC5

    class C1,C2,C3,C4,C5,C7,C8,C9,C10,C11,C12 stepNode
    class C6 decisionNode
    class SC1,SC2,SC3,SC4,SC5 stageBox
