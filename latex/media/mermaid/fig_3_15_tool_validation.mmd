---
config:
  theme: base
  themeVariables:
    fontFamily: 'Helvetica, Arial, sans-serif'
    fontSize: '15px'
    primaryColor: '#EAF2FB'
    primaryBorderColor: '#1A73E8'
    primaryTextColor: '#1A2330'
    lineColor: '#5F6368'
    tertiaryColor: '#F5F7FA'
---
%%{init: {'flowchart': {'curve': 'linear'}}}%%
flowchart TB
    classDef stepNode fill:#EAF2FB,stroke:#1A73E8,color:#1A2330
    classDef decisionNode fill:#FEF7E0,stroke:#B06000,color:#5C3C00
    classDef blockedNode fill:#FCE8E6,stroke:#C5221F,color:#8C1D18
    classDef stageBox fill:#FFFFFF,stroke:#5F6368,color:#1A2330

    subgraph V1["1. Tool Call Request"]
        R1["Model requests a tool call"]
    end

    subgraph V2["2. Validation Pipeline"]
        R2["Check tool exists<br/>in Tool Registry"] --> R3["Validate parameters<br/>against schema"] --> R4["Apply runtime<br/>Tool Policy"]
    end

    D1{"Allowed?"}

    subgraph V3["4. Tool Execution"]
        R5["Execute tool"] --> R6["Persist tool call<br/>and result"]
    end

    subgraph V4["5. Model Feedback"]
        R7["Return result to model"] --> R8["Model continues reasoning<br/>or finalizes response"]
    end

    R9["Return policy error"]:::blockedNode

    V1 --> V2 --> D1
    D1 -- No --> R9 --> R7
    D1 -- Yes --> V3 --> R7
    V4

    class R1,R2,R3,R4,R5,R6,R7,R8 stepNode
    class D1 decisionNode
    class V1,V2,V3,V4 stageBox
