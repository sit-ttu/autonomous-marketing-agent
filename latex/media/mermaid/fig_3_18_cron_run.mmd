---
config:
  theme: base
  themeVariables:
    fontFamily: 'Helvetica, Arial, sans-serif'
    fontSize: '15px'
    primaryColor: '#EAF2FB'
    primaryBorderColor: '#1A73E8'
    primaryTextColor: '#1A2330'
    lineColor: '#5F6368'
    tertiaryColor: '#F5F7FA'
---
%%{init: {'flowchart': {'curve': 'linear'}}}%%
flowchart TB
    classDef stepNode fill:#EAF2FB,stroke:#1A73E8,color:#1A2330
    classDef decisionNode fill:#FEF7E0,stroke:#B06000,color:#5C3C00
    classDef stageBox fill:#FFFFFF,stroke:#5F6368,color:#1A2330

    subgraph J1["1. Job Definition"]
        D1["Create / Update<br/>Cron Job"] --> D2["Persist Job<br/>Configuration"] --> D3["jobs.json"]
    end

    subgraph J2["2. Scheduling"]
        D4["Compute nextRunAt"] --> D5["Wait until<br/>job is due"]
    end

    subgraph J3["3. Payload Execution"]
        D6["Run Payload"] --> D7{"Payload kind?"}
        D7 -- systemEvent --> D8["Append System Event"]
        D7 -- agentTurn --> D9["Dispatch Agent Runtime"]
    end

    subgraph J4["4. Optional Delivery"]
        D10["Optional Message Delivery"]
    end

    subgraph J5["5. Logging and State Update"]
        D11["Write Run Log"] --> D12["Update Job State"] --> D13["Next cycle: return to step 2<br/>to recompute nextRunAt"]
    end

    J1 --> J2 --> J3
    D8 --> J4
    D9 --> J4
    J4 --> J5

    class D1,D2,D3,D4,D5,D6,D8,D9,D10,D11,D12,D13 stepNode
    class D7 decisionNode
    class J1,J2,J3,J4,J5 stageBox
