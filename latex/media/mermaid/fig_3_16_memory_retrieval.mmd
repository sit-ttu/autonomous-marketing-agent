---
config:
  theme: base
  themeVariables:
    fontFamily: 'Helvetica, Arial, sans-serif'
    fontSize: '15px'
    primaryColor: '#EAF2FB'
    primaryBorderColor: '#1A73E8'
    primaryTextColor: '#1A2330'
    lineColor: '#5F6368'
    tertiaryColor: '#F5F7FA'
---
%%{init: {'flowchart': {'curve': 'linear'}}}%%
flowchart TB
    classDef stepNode fill:#EAF2FB,stroke:#1A73E8,color:#1A2330
    classDef decisionNode fill:#FEF7E0,stroke:#B06000,color:#5C3C00
    classDef stageBox fill:#FFFFFF,stroke:#5F6368,color:#1A2330

    subgraph N1["1. Input Brief"]
        B1["Current Brief"] --> B2{"Need prior context?"}
    end

    subgraph N2["2. Memory Retrieval"]
        B3["memory_search Query"] --> B4["SQLite Memory Index"] --> B5["Relevant Chunks"]
    end

    subgraph N3["3. Context Construction"]
        B6["Context Assembly"] --> B7["Agent Reasoning"]
    end

    subgraph N4["4. Insight Capture"]
        B8["New Insight"] --> B9{"Useful for<br/>future runs?"}
        B9 -- Yes --> B10["Memory Flash"]
        B9 -- No --> B11["Discard"]
    end

    B2 -- Yes --> N2
    B2 -- No --> N3
    B5 --> N3
    B7 --> N4
    B10 -. "update memory index" .-> B4

    class B1,B3,B4,B5,B6,B7,B8,B10,B11 stepNode
    class B2,B9 decisionNode
    class N1,N2,N3,N4 stageBox
