---
config:
  theme: base
  themeVariables:
    fontFamily: 'Helvetica, Arial, sans-serif'
    fontSize: '15px'
    primaryColor: '#EAF2FB'
    primaryBorderColor: '#1A73E8'
    primaryTextColor: '#1A2330'
    lineColor: '#5F6368'
    tertiaryColor: '#F5F7FA'
---
%%{init: {'flowchart': {'curve': 'linear'}}}%%
flowchart TD
    classDef startEnd fill:#E6F4EA,stroke:#137333,color:#0D652D
    classDef normal fill:#EAF2FB,stroke:#1A73E8,color:#1A2330
    classDef decision fill:#FEF7E0,stroke:#B06000,color:#5C3C00
    classDef approval fill:#FEF3E7,stroke:#E37400,color:#7A3E00
    classDef blocked fill:#FCE8E6,stroke:#C5221F,color:#8C1D18

    Start(["Receive brief /<br/>marketing request"]):::startEnd
    Ctx["Load context:<br/>Session + Memory + Brand Context"]:::normal
    Reason{"LLM reasoning:<br/>tool call needed?"}:::decision
    Sensitive{"Is the action sensitive?<br/>(publish post, bulk message,<br/>budget change)"}:::decision
    Approval["Create Approval request,<br/>wait for user decision"]:::approval
    Decision{"User decision"}:::decision
    Blocked["Block action,<br/>log rejection reason"]:::blocked
    PolicyCheck["Tool Policy checks permission"]:::normal
    Execute["Execute tool"]:::normal
    Observe["Observe tool result"]:::normal
    Respond["Generate final response"]:::normal
    Persist["Persist Transcript,<br/>update Memory / Insight"]:::normal
    Deliver(["Deliver result<br/>via channel"]):::startEnd

    Start --> Ctx --> Reason
    Reason -- No --> Respond
    Reason -- Yes --> Sensitive
    Sensitive -- No --> PolicyCheck
    Sensitive -- Yes --> Approval
    Approval --> Decision
    Decision -- "Rejected / expired" --> Blocked
    Blocked --> Reason
    Decision -- Approved --> PolicyCheck
    PolicyCheck --> Execute --> Observe --> Reason
    Respond --> Persist --> Deliver
